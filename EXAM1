#DATOS VERTICALESS
def metodo_verticales(soporte_min, producto_filtro):
    transacciones_vertical = datos.groupby("id_producto")["id_tienda"].apply(set).to_dict()

    total = datos["id_tienda"].nunique()
    nombres_productos = datos.groupby("id_producto")["tipo_Producto"].first().to_dict()
    resultados = []

    for producto, tiendas in transacciones_vertical.items():
        frecuencia = len(tiendas)
        soporte = frecuencia / total
        if soporte >= soporte_min:
            resultados.append(( nombres_productos[producto], tiendas, frecuencia,round(soporte*100,2)))
    return resultados

