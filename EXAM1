#ALGORITMOO LIFTT
def algoritmo_lift(producto_filtro, relacion_filtro):
    transacciones = datos.groupby("id_tienda")["id_producto"].apply(list)
    total = len(transacciones)

    nombres_productos = datos.groupby("id_producto")["tipo_Producto"].first().to_dict()

    soporte_individual = {}
    conteo_pares = {}

    for productos in transacciones:
        productos = list(set(productos))
        for p in productos:
            if p in soporte_individual:
                soporte_individual[p] += 1
            else:
                soporte_individual[p] = 1

        for i in range(len(productos)):
            for j in range(i+1, len(productos)):
                par = (productos[i], productos[j])

                if par in conteo_pares:
                    conteo_pares[par] += 1
                else:
                    conteo_pares[par] = 1
    resultados = []

    for par in conteo_pares:
        productoA = par[0]
        productoB = par[1]

        cantidad = conteo_pares[par]

        soporte_ab = cantidad / total
        soporte_a = soporte_individual[productoA] / total
        soporte_b = soporte_individual[productoB] / total

        lift = soporte_ab / (soporte_a * soporte_b)

        nombreA = nombres_productos[productoA]
        nombreB = nombres_productos[productoB]

        mostrar = True
        if producto_filtro.lower() != "todos":
            if producto_filtro.lower() not in nombreA.lower() and producto_filtro.lower() not in nombreB.lower():
                mostrar = False

        if lift > 1:
            resultado = "Asociación positiva"
        elif lift < 1:
            resultado = "Asociación negativa"
        else:
            resultado = "Independencia"

        if relacion_filtro == "Mayor a 1 (>1)" and lift <= 1:
            mostrar = False

        if relacion_filtro == "Menor a 1 (<1)" and lift >= 1:
            mostrar = False

        if relacion_filtro == "Igual a 1 (=1)" and round(lift,2) != 1:
            mostrar = False


        if mostrar == True:
            resultados.append((nombreA, nombreB, round(lift,2), resultado ))
    return resultados[:500]


